#include<iostream>
#include<string.h>
using namespace std;

int main(){
    cout<<"Enter the password to check:\n";
    cout<<"Rules: Must include uppercase, lowercase, number and symbol (@ or #)\n";

    char str[100];
    cin>>str;

    int n = strlen(str);

    int hasUpper = 0, hasLower = 0, hasDigit = 0, hasSymbol = 0;

    for(int i=0; i<n; i++){
        if(str[i] >= '0' && str[i] <= '9'){
            hasDigit = 1;
        }
        else if(str[i] >= 'a' && str[i] <= 'z'){
            hasLower = 1;
        }
        else if(str[i] >= 'A' && str[i] <= 'Z'){
            hasUpper = 1;
        }
        else if(str[i] == '@' || str[i] == '#'){
            hasSymbol = 1;
        }
    }

    if(hasUpper && hasLower && hasDigit && hasSymbol){
        cout<<"GOOD PASSWORD";
    }
    else{
        cout<<"INVALID PASSWORD";
    }

    return 0;
}
